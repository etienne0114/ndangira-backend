generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  label     String
  isSystem  Boolean   @default(false)
  createdAt DateTime  @default(now())
  Listing   Listing[]
}

model Listing {
  id              String          @id @default(cuid())
  title           String
  description     String
  priceRwf        Int
  unitLabel       String
  inventoryStatus InventoryStatus @default(IN_STOCK)
  isFeatured      Boolean         @default(false)
  freshnessNote   String?
  imageUrl        String?
  tags            String[]
  merchantId      String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  categoryId      String
  Category        Category        @relation(fields: [categoryId], references: [id])
  Merchant        Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([categoryId, isFeatured])
  @@index([title])
}

model Merchant {
  id              String          @id @default(cuid())
  businessName    String
  ownerName       String
  phone           String
  whatsapp        String?
  neighborhood    String
  district        String
  latitude        Float
  longitude       Float
  verified        Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  addressLine     String?
  aiEnabled       Boolean         @default(true)
  description     String?
  serviceRadiusKm Int             @default(5)
  userId          String?         @unique
  email           String          @unique
  passwordHash    String
  businessType    ListingCategory
  Listing         Listing[]
  User            User?           @relation(fields: [userId], references: [id])

  @@index([neighborhood])
  @@index([businessType, neighborhood])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  User      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, read])
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  role         UserRole       @default(CUSTOMER)
  sellerStatus SellerStatus?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  Merchant     Merchant?
  Notification Notification[]
}

enum InventoryStatus {
  IN_STOCK
  LOW_STOCK
  MADE_TO_ORDER
}

enum NotificationType {
  SELLER_APPROVED
  SELLER_REJECTED
  LISTING_CREATED
  LISTING_LOW_STOCK
  NEW_SELLER_APPLICATION
  SYSTEM_ANNOUNCEMENT
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  ADMIN
  SELLER
  CUSTOMER
}

enum ListingCategory {
  GROCERIES
  RESTAURANTS
  FASHION
  ELECTRONICS
  HOME
  HEALTH
  SERVICES
  SUPERMARKET
  PHARMACY
  HOUSING
}
